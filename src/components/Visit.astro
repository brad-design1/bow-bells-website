---
const hours = [
  { day: 'Mon — Fri', time: '7:00 — 17:00' },
  { day: 'Saturday',  time: '7:30 — 17:00' },
  { day: 'Sunday',    time: '8:00 — 15:00' },
];
---

<section class="visit section" id="visit">
  <div class="container">
    <div class="visit-grid">
      <div class="visit-content reveal">
        <span class="eyebrow">Visit</span>
        <h2 class="visit-title">
          Corner of High Street.
          <span class="italic-serif">Black facade, gold lettering.</span>
        </h2>
        <p class="visit-lede">
          You can't miss it. Come in, order at the counter, grab a seat by the
          window. Or call ahead if you want to be sure we've still got sausage
          rolls in the case.
        </p>

        <dl class="visit-details">
          <div>
            <dt>Address</dt>
            <dd>
              27 High Street<br />
              Donaghadee, Co. Down<br />
              BT21 0AH
            </dd>
          </div>
          <div>
            <dt>Call</dt>
            <dd>
              <a href="tel:+442891882020">+44 28 9188 2020</a>
            </dd>
          </div>
          <div>
            <dt>Hours</dt>
            <dd>
              <ul class="hours-list">
                {hours.map((h) => (
                  <li><span>{h.day}</span><span>{h.time}</span></li>
                ))}
              </ul>
            </dd>
          </div>
        </dl>

        <div class="visit-cta">
          <a href="#order" class="btn btn-primary" id="order">Order online</a>
          <a
            href="https://maps.google.com/?q=Bow+Bells+Donaghadee"
            target="_blank"
            rel="noopener"
            class="btn btn-ghost"
          >Get directions</a>
        </div>
      </div>

      <aside class="visit-map reveal">
        <div class="map-frame">
          <iframe
            title="Map of Bow Bells location in Donaghadee"
            src="https://www.google.com/maps/embed/v1/place?key=&q=Donaghadee,Northern+Ireland"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
          <noscript><p>Map requires JavaScript</p></noscript>
          <!-- Fallback visual when iframe can't load (e.g. no API key) -->
          <div class="map-fallback" aria-hidden="true">
            <img
              src="https://images.unsplash.com/photo-1519662978799-8c2bbf17e4d2?w=1200&q=75"
              alt=""
            />
            <div class="map-pin">
              <div class="map-pin-dot"></div>
              <div class="map-pin-label">
                <strong>Bow Bells</strong>
                <span>27 High Street</span>
              </div>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .visit {
    background: var(--cream-soft);
  }

  .visit-grid {
    display: grid;
    grid-template-columns: 5fr 6fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: stretch;
  }

  .visit-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    margin: 20px 0 28px;
    max-width: 18ch;
    line-height: 1.05;
  }

  .visit-title .italic-serif { color: var(--amber); }

  .visit-lede {
    color: var(--warm-grey);
    max-width: 50ch;
    font-size: 1.02rem;
    margin-bottom: 40px;
  }

  .visit-details {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px 36px;
    padding: 32px 0;
    border-top: 1px solid rgba(61, 35, 20, 0.12);
    border-bottom: 1px solid rgba(61, 35, 20, 0.12);
    margin-bottom: 36px;
  }

  .visit-details dt {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--warm-grey);
    margin-bottom: 10px;
  }

  .visit-details dd {
    font-family: 'Fraunces', serif;
    font-size: 1.05rem;
    color: var(--rich-brown);
    line-height: 1.55;
  }

  .visit-details a { transition: color 0.3s ease; }
  .visit-details a:hover { color: var(--amber); }

  .hours-list {
    list-style: none;
    display: grid;
    gap: 8px;
  }

  .hours-list li {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    font-family: 'Inter', sans-serif;
    font-size: 0.92rem;
  }

  .hours-list li span:first-child {
    color: var(--warm-grey);
  }

  .visit-cta { display: flex; gap: 14px; flex-wrap: wrap; }

  .visit-map {
    position: relative;
    min-height: 520px;
  }

  .map-frame {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 520px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    background: var(--clay);
  }

  .map-frame iframe {
    width: 100%;
    height: 100%;
    border: 0;
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0; /* hidden unless you add a Google Maps API key */
  }

  .map-fallback {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .map-fallback img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.7) brightness(0.85) sepia(0.15);
  }

  .map-pin {
    position: absolute;
    left: 50%;
    top: 46%;
    transform: translate(-50%, -100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .map-pin-dot {
    width: 18px;
    height: 18px;
    background: var(--amber);
    border-radius: 50%;
    box-shadow: 0 0 0 6px rgba(193, 120, 23, 0.25), 0 6px 20px rgba(30, 25, 18, 0.3);
    animation: pinPulse 2.4s ease-in-out infinite;
  }

  @keyframes pinPulse {
    0%, 100% { box-shadow: 0 0 0 6px rgba(193, 120, 23, 0.25), 0 6px 20px rgba(30, 25, 18, 0.3); }
    50%      { box-shadow: 0 0 0 14px rgba(193, 120, 23, 0.05), 0 6px 20px rgba(30, 25, 18, 0.3); }
  }

  .map-pin-label {
    background: var(--cream);
    padding: 10px 16px;
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .map-pin-label strong {
    font-family: 'Fraunces', serif;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--rich-brown);
  }

  .map-pin-label span {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--warm-grey);
  }

  @media (max-width: 860px) {
    .visit-grid { grid-template-columns: 1fr; }
    .visit-map { min-height: 380px; }
    .map-frame { min-height: 380px; }
    .visit-details { grid-template-columns: 1fr; gap: 20px; }
  }
</style>
