---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <span class="footer-logo serif">Bow Bells</span>
        <p class="footer-tag italic-serif">Donaghadee, since 1975.</p>
      </div>

      <div class="footer-col">
        <h4>Shop</h4>
        <ul>
          <li><a href="#menu">Menu</a></li>
          <li><a href="#order">Order online</a></li>
          <li><a href="#">Gift cards</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Visit</h4>
        <ul>
          <li><a href="#visit">27 High Street, BT21 0AH</a></li>
          <li><a href="tel:+442891882020">+44 28 9188 2020</a></li>
          <li><a href="mailto:hello@bowbells.com">hello@bowbells.com</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Follow</h4>
        <ul>
          <li><a href="#">Facebook</a></li>
          <li><a href="#">Instagram</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bar">
      <span>© {year} Bow Bells Coffee House & Bakery Ltd.</span>
      <span class="italic-serif">Baked with patience.</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--espresso);
    color: var(--cream);
    padding: clamp(3rem, 7vw, 5rem) 0 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(245, 240, 232, 0.14);
  }

  .footer-logo {
    font-size: 2rem;
    font-weight: 500;
    line-height: 1;
    color: var(--cream);
  }

  .footer-tag {
    margin-top: 8px;
    color: rgba(245, 240, 232, 0.7);
    font-size: 1rem;
  }

  .footer-col h4 {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 18px;
  }

  .footer-col ul {
    list-style: none;
    display: grid;
    gap: 10px;
  }

  .footer-col a {
    font-size: 0.92rem;
    color: rgba(245, 240, 232, 0.84);
    transition: color 0.3s ease;
  }

  .footer-col a:hover { color: var(--amber); }

  .footer-bar {
    display: flex;
    justify-content: space-between;
    padding-top: 24px;
    font-size: 0.8rem;
    color: rgba(245, 240, 232, 0.55);
  }

  @media (max-width: 720px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
    .footer-brand { grid-column: 1 / -1; }
    .footer-bar { flex-direction: column; gap: 8px; text-align: center; }
  }
</style>
