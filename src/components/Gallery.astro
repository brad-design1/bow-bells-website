---
import InfiniteScrollGallery from './InfiniteScrollGallery.tsx';
import { galleryRowA, galleryRowB } from '../data/site';
---

<section class="gallery section" id="gallery">
  <div class="container">
    <header class="gallery-head reveal">
      <span class="eyebrow">In the shop</span>
      <h2 class="gallery-title">
        A day,
        <span class="italic-serif">on a loop.</span>
      </h2>
      <p class="gallery-sub">
        From the first pull of espresso at 6:45 to the last scone at 4pm —
        a continuous reel of what actually happens inside our kitchen.
        Hover anything to slow it down.
      </p>
    </header>
  </div>

  <!-- Full-bleed marquee -->
  <InfiniteScrollGallery
    client:visible
    rowA={galleryRowA}
    rowB={galleryRowB}
  />

  <div class="container">
    <div class="gallery-foot reveal">
      <p class="gallery-note">
        <span class="italic-serif">Follow along</span> — we post the day's
        bakes to Facebook and Instagram every morning.
      </p>
      <div class="gallery-socials">
        <a href="#" aria-label="Facebook" class="social">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22 12a10 10 0 10-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.3 0-1.6.8-1.6 1.5V12h2.8l-.5 2.9h-2.3v7A10 10 0 0022 12z" />
          </svg>
          <span>Facebook</span>
        </a>
        <a href="#" aria-label="Instagram" class="social">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
          <span>Instagram</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .gallery {
    background: var(--espresso);
    color: var(--cream);
    padding: clamp(4rem, 10vw, 8rem) 0 clamp(3rem, 7vw, 5rem);
    overflow: hidden;
  }

  .gallery-head {
    max-width: 820px;
    margin-bottom: 56px;
  }

  .gallery-head .eyebrow { color: var(--amber); }
  .gallery-head .eyebrow::before { background: var(--amber); }

  .gallery-title {
    font-size: clamp(2.4rem, 6vw, 4.8rem);
    margin: 20px 0 24px;
    color: var(--cream);
    line-height: 1;
  }

  .gallery-title .italic-serif { color: var(--amber); }

  .gallery-sub {
    color: rgba(245, 240, 232, 0.76);
    max-width: 52ch;
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .gallery-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-top: 52px;
    padding-top: 36px;
    border-top: 1px solid rgba(245, 240, 232, 0.14);
    flex-wrap: wrap;
  }

  .gallery-note {
    font-size: 1.05rem;
    color: rgba(245, 240, 232, 0.84);
    max-width: 48ch;
  }

  .gallery-note .italic-serif { color: var(--amber); }

  .gallery-socials {
    display: flex;
    gap: 12px;
  }

  .social {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 18px;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(245, 240, 232, 0.3);
    font-size: 0.85rem;
    color: var(--cream);
    transition: background-color 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }

  .social:hover {
    background: var(--amber);
    border-color: var(--amber);
    color: var(--white);
    transform: translateY(-2px);
  }
</style>
