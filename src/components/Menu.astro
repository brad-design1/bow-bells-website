---
import MenuCarousel from './MenuCarousel.tsx';
import { menuItems } from '../data/site';
---

<section class="menu section" id="menu">
  <div class="container">
    <header class="menu-head reveal">
      <span class="eyebrow">The Menu</span>
      <h2 class="menu-title">
        Baked fresh every morning.<br />
        <span class="italic-serif">Gone by afternoon.</span>
      </h2>
      <p class="menu-sub">
        A rotating selection pulled from the ovens. Prices held since
        the weather was decent. Everything in the case today was made today.
      </p>
    </header>

    <MenuCarousel client:visible items={menuItems} />

    <div class="menu-foot reveal">
      <a href="#" class="btn btn-ghost">See the full menu →</a>
    </div>
  </div>
</section>

<style>
  .menu { background: var(--cream); }

  .menu-head {
    max-width: 820px;
    margin-bottom: 60px;
  }

  .menu-title {
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    margin: 20px 0 24px;
    line-height: 1.05;
  }

  .menu-sub {
    color: var(--warm-grey);
    max-width: 52ch;
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .menu-foot {
    margin-top: 48px;
    display: flex;
    justify-content: center;
  }
</style>
